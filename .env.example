# ── Database ──
# Local dev: standard PostgreSQL connection
# GCP Cloud Run: uses Cloud SQL Auth Proxy socket
DATABASE_URL="postgresql://user:pass@host:5432/periwink"

# ── Auth ──
NEXTAUTH_SECRET="generate-a-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# ── Admin ──
# Password for /admin dashboard and /api/admin/* routes
ADMIN_SECRET="change-this-in-production"

# ── Email (Resend) ──
RESEND_API_KEY=""

# ── GCP (production only, set via Secret Manager) ──
# These are injected by Cloud Run from Secret Manager — do not set locally
# DATABASE_URL=periwink-database-url:latest
# NEXTAUTH_SECRET=periwink-nextauth-secret:latest
# RESEND_API_KEY=periwink-resend-api-key:latest
